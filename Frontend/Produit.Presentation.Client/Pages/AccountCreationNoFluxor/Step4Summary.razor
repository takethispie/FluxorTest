@using Produit.Presentation.Client.Models

@if (!Wizard.IsSubmitted)
{
    <div style="max-width: 640px;">
        <h5 class="mb-3">Review your information</h5>

        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Personal Info</strong>
                @if (Wizard.Step1Valid)
                { <span class="badge bg-success">✓ Validated</span> }
                else
                { <span class="badge bg-warning text-dark">Not validated</span> }
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Wizard.UserInfo.FirstName @Wizard.UserInfo.LastName</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Wizard.UserInfo.Email</dd>
                    <dt class="col-sm-4">Birth Date</dt>
                    <dd class="col-sm-8">@Wizard.UserInfo.BirthDate.ToString("yyyy-MM-dd")</dd>
                </dl>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Hobbies (@Wizard.Hobbies.Count)</strong>
                @if (Wizard.Step2Valid)
                { <span class="badge bg-success">✓ Validated</span> }
                else
                { <span class="badge bg-warning text-dark">Not validated</span> }
            </div>
            @if (Wizard.Hobbies.Count > 0)
            {
                <ul class="list-group list-group-flush">
                    @foreach (var h in Wizard.Hobbies)
                    {
                        <li class="list-group-item">
                            <strong>@h.Name</strong>
                            @if (!string.IsNullOrWhiteSpace(h.Description))
                            { <span class="text-muted"> — @h.Description</span> }
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="card-body text-muted">No hobbies added.</div>
            }
        </div>

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Vehicles (@Wizard.Vehicles.Count)</strong>
                @if (Wizard.Step3Valid)
                { <span class="badge bg-success">✓ Validated</span> }
                else
                { <span class="badge bg-warning text-dark">Not validated</span> }
            </div>
            @if (Wizard.Vehicles.Count > 0)
            {
                <ul class="list-group list-group-flush">
                    @foreach (var v in Wizard.Vehicles)
                    {
                        <li class="list-group-item">
                            <strong>@v.Year @v.Make @v.Model</strong>
                            @if (!string.IsNullOrWhiteSpace(v.LicensePlate))
                            { <span class="badge bg-secondary ms-2">@v.LicensePlate</span> }
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="card-body text-muted">No vehicles added.</div>
            }
        </div>

        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-success" @onclick="() => Wizard.SubmitAccount()" disabled="@(!AllValid)">✓ Finalize</button>
            @if (!AllValid)
            {
                <span class="text-danger small">All steps must be validated before finalizing.</span>
            }
        </div>
    </div>
}
else
{
    <div class="alert alert-success" style="max-width: 640px;">
        <h4 class="alert-heading">🎉 Account Created!</h4>
        <p>Welcome, <strong>@Wizard.UserInfo.FirstName @Wizard.UserInfo.LastName</strong>!</p>
        <p class="mb-0">@Wizard.Hobbies.Count hobby(ies) · @Wizard.Vehicles.Count vehicle(s)</p>
        <hr />
        <button class="btn btn-outline-success" @onclick="() => Wizard.Reset()">Start Over</button>
    </div>
}

@code {
    [Parameter, EditorRequired] public WizardLayout Wizard { get; set; } = default!;

    private bool AllValid => Wizard.Step1Valid && Wizard.Step2Valid && Wizard.Step3Valid;
}
