@inject FakeAccountDatabase Db
@using Produit.Presentation.Client.Models
@using Produit.Presentation.Client.Services

<PageTitle>Account Creation (No Fluxor) – Step @_currentStep</PageTitle>
@if (OnSaved.HasDelegate)
{
    <h2 class="mb-1">@(AccountToLoad is null ? "Create" : "Edit") Account <small class="text-muted fs-6">(No Fluxor)</small></h2>
}
else
{
    <h2 class="mb-1">Create Account <small class="text-muted fs-6">(No Fluxor)</small></h2>
}
<AccountCreationBreadcrumb CurrentStep="_currentStep"
    Step1Valid="Step1Valid"
    Step2Valid="Step2Valid"
    Step3Valid="Step3Valid" />

@switch (_currentStep)
{
    case 1: <Produit.Presentation.Client.Pages.AccountCreationNoFluxor.Step1UserInfo Wizard="this" /> break;
    case 2: <Produit.Presentation.Client.Pages.AccountCreationNoFluxor.Step2Hobbies Wizard="this" /> break;
    case 3: <Produit.Presentation.Client.Pages.AccountCreationNoFluxor.Step3Vehicles Wizard="this" /> break;
    case 4: <Produit.Presentation.Client.Pages.AccountCreationNoFluxor.Step4Summary Wizard="this" /> break;
}

@code {
    [Parameter] public UserAccountModel? AccountToLoad { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private int _currentStep = 1;

    // ── Wizard state ─────────────────────────────────────────────────────────
    public Guid Id { get; private set; } = Guid.NewGuid();
    public UserInfo UserInfo { get; private set; } = new();
    public List<Hobby> Hobbies { get; private set; } = [];
    public List<Vehicle> Vehicles { get; private set; } = [];

    public bool Step1Valid { get; private set; }
    public bool Step2Valid { get; private set; }
    public bool Step3Valid { get; private set; }
    public bool IsSubmitted { get; private set; }

    protected override void OnParametersSet()
    {
        if (AccountToLoad is not null)
        {
            Id = AccountToLoad.Id;
            UserInfo = AccountToLoad.UserInfo;
            Hobbies = [.. AccountToLoad.Hobbies];
            Vehicles = [.. AccountToLoad.Vehicles];
            Step1Valid = true;
            Step2Valid = Hobbies.Count > 0;
            Step3Valid = Vehicles.Count > 0;
            _currentStep = 1;
        }
    }

    // ── Step 1 ───────────────────────────────────────────────────────────────
    public void SaveUserInfo(UserInfo info)
    {
        UserInfo = info;
        StateHasChanged();
    }

    public bool ValidateUserInfo(string firstName, string lastName, string email)
    {
        Step1Valid = !string.IsNullOrWhiteSpace(firstName)
                  && !string.IsNullOrWhiteSpace(lastName)
                  && !string.IsNullOrWhiteSpace(email);
        if (Step1Valid) _currentStep = 2;
        StateHasChanged();
        return Step1Valid;
    }

    // ── Step 2 ───────────────────────────────────────────────────────────────
    public void AddHobby(Hobby hobby)
    {
        Hobbies = [.. Hobbies, hobby];
        StateHasChanged();
    }

    public void RemoveHobby(Guid id)
    {
        Hobbies = Hobbies.Where(h => h.Id != id).ToList();
        StateHasChanged();
    }

    public bool ValidateHobbies()
    {
        Step2Valid = Hobbies.Count > 0;
        if (Step2Valid) _currentStep = 3;
        StateHasChanged();
        return Step2Valid;
    }

    // ── Step 3 ───────────────────────────────────────────────────────────────
    public void AddVehicle(Vehicle vehicle)
    {
        Vehicles = [.. Vehicles, vehicle];
        StateHasChanged();
    }

    public void RemoveVehicle(Guid id)
    {
        Vehicles = Vehicles.Where(v => v.Id != id).ToList();
        StateHasChanged();
    }

    public bool ValidateVehicles()
    {
        Step3Valid = Vehicles.Count > 0;
        if (Step3Valid) _currentStep = 4;
        StateHasChanged();
        return Step3Valid;
    }

    // ── Step 4 ───────────────────────────────────────────────────────────────
    public void SubmitAccount()
    {
        Db.Upsert(new UserAccountModel
        {
            Id = Id,
            UserInfo = UserInfo,
            Hobbies = Hobbies,
            Vehicles = Vehicles
        });
        IsSubmitted = true;
        StateHasChanged();
        if (OnSaved.HasDelegate)
            OnSaved.InvokeAsync();
    }

    public void Reset()
    {
        Id = Guid.NewGuid();
        UserInfo = new();
        Hobbies = [];
        Vehicles = [];
        Step1Valid = false;
        Step2Valid = false;
        Step3Valid = false;
        IsSubmitted = false;
        _currentStep = 1;
        StateHasChanged();
    }
}
