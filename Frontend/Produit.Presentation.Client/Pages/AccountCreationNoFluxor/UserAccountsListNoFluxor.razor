@page "/no-fluxor-accounts"
@inject FakeAccountDatabase Db
@inject NavigationManager Nav
@using Produit.Presentation.Client.Models
@using Produit.Presentation.Client.Services

<PageTitle>User Accounts (No Fluxor)</PageTitle>
<h2 class="mb-3">User Accounts <small class="text-muted fs-6">(No Fluxor)</small></h2>

<div class="d-flex gap-2 mb-3">
    <button class="btn btn-primary" @onclick="Refresh">↻ Refresh</button>
    <button class="btn btn-success" @onclick="NewAccount">+ New Account</button>
</div>

@if (_accounts.Count == 0)
{
    <p class="text-muted">No accounts found.</p>
}
else
{
    <table class="table table-hover" style="max-width: 860px;">
        <thead>
            <tr><th>Name</th><th>Email</th><th>Hobbies</th><th>Vehicles</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var a in _accounts)
            {
                <tr>
                    <td>@a.UserInfo.FirstName @a.UserInfo.LastName</td>
                    <td>@a.UserInfo.Email</td>
                    <td>@a.Hobbies.Count</td>
                    <td>@a.Vehicles.Count</td>
                    <td>@(a.EstBrouillon ? "En Brouillon" : "Validé")</td>
                    <td class="d-flex gap-1">
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(a)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(a.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_showWizard)
{
    <hr />
    <WizardLayout @ref="_wizard" AccountToLoad="_accountToEdit" OnSaved="HandleSaved" />
}

@code {
    private List<UserAccountModel> _accounts = [];
    private bool _showWizard;
    private UserAccountModel? _accountToEdit;
    private WizardLayout? _wizard;

    protected override void OnInitialized() => Refresh();

    private void Refresh()
    {
        _accounts = Db.GetAll();
        StateHasChanged();
    }

    private void NewAccount()
    {
        _accountToEdit = null;
        _showWizard = true;
    }

    private void Edit(UserAccountModel account)
    {
        _accountToEdit = account;
        _showWizard = true;
    }

    private void Delete(Guid id)
    {
        Db.Delete(id);
        Refresh();
    }

    private void HandleSaved()
    {
        _showWizard = false;
        _accountToEdit = null;
        Refresh();
    }
}
