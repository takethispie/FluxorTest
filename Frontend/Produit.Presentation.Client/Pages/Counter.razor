@page "/counter"

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p class="text-muted mb-4">
    This counter stores state directly in the component.
    Compare with the <a href="/fluxor-counter">Fluxor counter</a> which uses a centralized store.
</p>

<div class="card mb-4" style="max-width: 480px;">
    <div class="card-body">
        <h5 class="card-title">Component State</h5>
        <p role="status" class="fs-4">
            Current count: <strong>@currentCount</strong>
        </p>
        <p class="text-muted small">
            Increment amount: <strong>@incrementAmount</strong>
        </p>
    </div>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <button class="btn btn-primary" @onclick="Increment">
        + Increment (@incrementAmount)
    </button>
    <button class="btn btn-secondary" @onclick="Decrement">
        − Decrement (@incrementAmount)
    </button>
    <button class="btn btn-danger" @onclick="Reset">
        ↺ Reset
    </button>
</div>

<div class="mb-3" style="max-width: 320px;">
    <label class="form-label">Increment amount</label>
    <input type="number"
           class="form-control"
           min="1"
           @bind="incrementAmount" />
</div>

@code {
    private int currentCount = 0;
    private int incrementAmount = 1;

    private void Increment() => currentCount += incrementAmount;
    private void Decrement() => currentCount -= incrementAmount;
    private void Reset() => currentCount = 0;
}
