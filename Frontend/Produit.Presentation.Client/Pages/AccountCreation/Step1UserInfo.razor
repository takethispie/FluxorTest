@page "/account-creation/step1"
@inherits FluxorComponent
@inject IState<UserAccountState> AccountState
@inject IDispatcher Dispatcher
@inject NavigationManager Nav
@using Produit.Presentation.Client.Models
@using Produit.Presentation.Client.Store.UserAccount

<PageTitle>Account Creation – Step 1</PageTitle>
<h2 class="mb-1">Create Account</h2>
<AccountCreationBreadcrumb CurrentStep="1"
    Step1Valid="AccountState.Value.Step1Valid"
    Step2Valid="AccountState.Value.Step2Valid"
    Step3Valid="AccountState.Value.Step3Valid" />

<div class="card" style="max-width: 520px;">
    <div class="card-body">
        <h5 class="card-title">Personal Information</h5>
        <div class="mb-3">
            <label class="form-label">First Name *</label>
            <input class="form-control" @bind="_firstName" />
        </div>
        <div class="mb-3">
            <label class="form-label">Last Name *</label>
            <input class="form-control" @bind="_lastName" />
        </div>
        <div class="mb-3">
            <label class="form-label">Email *</label>
            <input type="email" class="form-control" @bind="_email" />
        </div>
        <div class="mb-4">
            <label class="form-label">Birth Date</label>
            <input type="date" class="form-control"
                   value="@_birthDate.ToString("yyyy-MM-dd")"
                   @onchange="e => { if (DateOnly.TryParse(e.Value?.ToString(), out var d)) _birthDate = d; }" />
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="Save">Save</button>
            <button class="btn btn-primary" @onclick="Validate">Validate</button>
        </div>
        @if (_showError)
        {
            <div class="text-danger mt-2 small">First name, last name and email are required.</div>
        }
    </div>
</div>

@code {
    private string _firstName = string.Empty;
    private string _lastName  = string.Empty;
    private string _email     = string.Empty;
    private DateOnly _birthDate = DateOnly.FromDateTime(DateTime.Today.AddYears(-18));
    private bool _showError;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        var s = AccountState.Value.UserInfo;
        _firstName = s.FirstName; 
        _lastName = s.LastName; 
        _email = s.Email;
        _birthDate = s.BirthDate == default ? DateOnly.FromDateTime(DateTime.Today.AddYears(-18)) : s.BirthDate;
    }

    private UserInfo BuildInfo() => new() { FirstName = _firstName, LastName = _lastName, Email = _email, BirthDate = _birthDate };

    private void Save()
    {
        _showError = AccountState.Value.Step1Valid;
        Dispatcher.Dispatch(new SaveUserInfoAction(BuildInfo()));
    }

    private void Validate()
    {
        Dispatcher.Dispatch(new ValidateUserInfoAction(_firstName, _lastName, _email));
    }
}
