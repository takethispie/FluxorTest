@page "/account-creation/step2"
@inherits FluxorComponent
@inject IState<UserAccountState> AccountState
@inject IDispatcher Dispatcher
@inject NavigationManager Nav
@using Produit.Presentation.Client.Store.UserAccount

<PageTitle>Account Creation – Step 2</PageTitle>
<h2 class="mb-1">Create Account</h2>
<AccountCreationBreadcrumb CurrentStep="2"
    Step1Valid="AccountState.Value.Step1Valid"
    Step2Valid="AccountState.Value.Step2Valid"
    Step3Valid="AccountState.Value.Step3Valid" />

<div class="card mb-4" style="max-width: 600px;">
    <div class="card-body">
        <h5 class="card-title">Add a Hobby</h5>
        <div class="mb-3">
            <label class="form-label">Name *</label>
            <input class="form-control" @bind="_name" placeholder="e.g. Photography" />
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            <input class="form-control" @bind="_desc" placeholder="Short description..." />
        </div>
        <button class="btn btn-success" @onclick="Add" disabled="@string.IsNullOrWhiteSpace(_name)">+ Add</button>
    </div>
</div>

@if (AccountState.Value.Hobbies.Count > 0)
{
    <ul class="list-group mb-4" style="max-width: 600px;">
        @foreach (var h in AccountState.Value.Hobbies)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><strong>@h.Name</strong>@(string.IsNullOrWhiteSpace(h.Description) ? "" : $" — {h.Description}")</span>
                <button class="btn btn-sm btn-outline-danger" @onclick="() => Dispatcher.Dispatch(new RemoveHobbyAction(h.Id))">✕</button>
            </li>
        }
    </ul>
}

<div class="d-flex gap-2" style="max-width: 600px;">
    <button class="btn btn-outline-secondary" @onclick="Save">Save</button>
    <button class="btn btn-primary" @onclick="Validate" disabled="@(AccountState.Value.Hobbies.Count == 0)">Validate</button>
</div>
@if (_showError)
{
    <div class="text-danger mt-2 small">Add at least one hobby to validate this step.</div>
}

@code {
    private string _name = string.Empty;
    private string _desc = string.Empty;
    private bool _showError;

    private void Add()
    {
        if (string.IsNullOrWhiteSpace(_name)) return;
        Dispatcher.Dispatch(new AddHobbyAction(new Hobby { Id = Guid.NewGuid(), Name = _name, Description = _desc }));
        _name = string.Empty; 
        _desc = string.Empty;
    }

    private void Save() => Dispatcher.Dispatch(new SaveAccountAction(new UserAccountModel
    {
        Id = AccountState.Value.Id,
        UserInfo = AccountState.Value.UserInfo,
        Hobbies = AccountState.Value.Hobbies,
        Vehicles = AccountState.Value.Vehicles
    }));

    private void Validate()
    {
        Dispatcher.Dispatch(new ValidateStep2Action());
        _showError = AccountState.Value.Hobbies.Count == 0;
    }
}
