@inject NavigationManager Nav
@using Produit.Presentation.Client.Store.UserAccount

<nav aria-label="Account creation steps" class="mb-4">
    <ol class="breadcrumb breadcrumb-wizard">
        @foreach (var step in _steps)
        {
            <li class="breadcrumb-item @GetItemClass(step)">
                @if (step.Step == CurrentStep)
                {
                    <span class="fw-bold">
                        @GetStatusIcon(step) @step.Label
                    </span>
                }
                else
                {
                    <a href="@step.Href" class="text-decoration-none">
                        @GetStatusIcon(step) @step.Label
                    </a>
                }
            </li>
        }
    </ol>
</nav>

@code {
    [Parameter, EditorRequired] public int CurrentStep { get; set; }
    [Parameter, EditorRequired] public bool Step1Valid { get; set; }
    [Parameter, EditorRequired] public bool Step2Valid { get; set; }
    [Parameter, EditorRequired] public bool Step3Valid { get; set; }

    private record StepInfo(int Step, string Label, string Href);

    private static readonly StepInfo[] _steps =
    [
        new(1, "Personal Info",  "/account-creation/step1"),
        new(2, "Hobbies",        "/account-creation/step2"),
        new(3, "Vehicles",       "/account-creation/step3"),
        new(4, "Summary",        "/account-creation/step4"),
    ];

    private bool IsValid(StepInfo step) => step.Step switch
    {
        1 => Step1Valid,
        2 => Step2Valid,
        3 => Step3Valid,
        4 => Step1Valid && Step2Valid && Step3Valid,
        _ => false
    };

    private string GetItemClass(StepInfo step)
    {
        if (step.Step == CurrentStep) return "active";
        if (IsValid(step)) return "text-success";
        return "text-muted";
    }

    private string GetStatusIcon(StepInfo step)
    {
        if (step.Step == CurrentStep) return "●";
        if (IsValid(step)) return "✓";
        return "○";
    }
}
