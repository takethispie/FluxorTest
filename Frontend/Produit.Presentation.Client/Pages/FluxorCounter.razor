@page "/fluxor-counter"
@inherits FluxorComponent
@inject IState<CounterState> CounterState
@inject  IDispatcher Dispatcher
@using Produit.Presentation.Client.Store.Counter

<PageTitle>Fluxor Counter</PageTitle>

<h1>Fluxor Counter</h1>

<p class="text-muted mb-4">
    This counter uses <strong>Fluxor</strong> (Redux pattern) to manage state.
    The count lives in a centralized store — not in the component itself.
    Compare with the <a href="/counter">normal counter</a> which stores state directly in the component.
</p>

<div class="card mb-4" style="max-width: 480px;">
    <div class="card-body">
        <h5 class="card-title">Store State</h5>
        <p role="status" class="fs-4">
            Current count: <strong>@CounterState.Value.Count</strong>
        </p>
        <p class="text-muted small">
            Increment amount: <strong>@CounterState.Value.IncrementAmount</strong>
        </p>
    </div>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <button class="btn btn-primary" @onclick="Increment">
        + Increment (@CounterState.Value.IncrementAmount)
    </button>
    <button class="btn btn-secondary" @onclick="Decrement">
        − Decrement (@CounterState.Value.IncrementAmount)
    </button>
    <button class="btn btn-danger" @onclick="Reset">
        ↺ Reset
    </button>
</div>

<div class="mb-3" style="max-width: 320px;">
    <label class="form-label">Increment amount</label>
    <input type="number"
           class="form-control"
           min="1"
           value="@CounterState.Value.IncrementAmount"
           @onchange="OnIncrementAmountChanged" />
</div>

<hr />

<h5>How it works (Fluxor)</h5>
<ol>
    <li>The component dispatches an <strong>Action</strong> (e.g. <code>IncrementCounterAction</code>).</li>
    <li>A <strong>Reducer</strong> receives the action and returns a new immutable <strong>State</strong>.</li>
    <li>Fluxor notifies all subscribed components — the UI re-renders automatically.</li>
</ol>

@code {
    private void Increment() =>
        Dispatcher.Dispatch(new IncrementCounterAction(CounterState.Value.IncrementAmount));

    private void Decrement() =>
        Dispatcher.Dispatch(new DecrementCounterAction(CounterState.Value.IncrementAmount));

    private void Reset() =>
        Dispatcher.Dispatch(new ResetCounterAction());

    private void OnIncrementAmountChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var amount) && amount > 0)
            Dispatcher.Dispatch(new SetIncrementAmountAction(amount));
    }
}
